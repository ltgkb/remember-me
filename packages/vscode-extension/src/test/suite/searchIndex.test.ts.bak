/**
 * Remember Me - SearchIndex 单元测试
 * 验证内存倒排索引的分词、构建、搜索和事件机制（B2 搜索索引优化）
 */

import * as assert from 'assert';
import * as fs from 'fs';
import * as path from 'path';
import * as os from 'os';
import { JsonStorage } from '../../memory/storage';
import {
  SearchIndex,
  getSearchIndex,
  tokenize,
  extractTextFromJson,
} from '../../utils/searchIndex';

describe('SearchIndex', () => {
  let tempDir: string;
  let storage: JsonStorage;

  beforeEach(() => {
    tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'remember-me-search-test-'));
    storage = new JsonStorage({ basePath: tempDir });
    SearchIndex.resetInstance();
  });

  afterEach(() => {
    fs.rmSync(tempDir, { recursive: true, force: true });
    SearchIndex.resetInstance();
  });

  // ==================== 分词测试 ====================

  describe('tokenize', () => {
    it('应将中文字符逐字切分', () => {
      const tokens = tokenize('权限管理设计');
      assert.deepStrictEqual(tokens, ['权', '限', '管', '理', '设', '计']);
    });

    it('应将英文按非字母数字切分并转小写', () => {
      const tokens = tokenize('Hello World! RBAC model.');
      assert.ok(tokens.includes('hello'));
      assert.ok(tokens.includes('world'));
      assert.ok(tokens.includes('rbac'));
      assert.ok(tokens.includes('model'));
    });

    it('应过滤单字符英文和纯数字', () => {
      const tokens = tokenize('a 1 test123 42');
      assert.ok(!tokens.includes('a'));
      assert.ok(!tokens.includes('1'));
      assert.ok(!tokens.includes('42'));
      assert.ok(tokens.includes('test123'));
    });
      assert.ok(tokens.includes('test123'));
      assert.ok(tokens.includes('test'));
    });

    it('应处理中英文混合文本', () => {
      const tokens = tokenize('我们需要支持 RBAC 权限模型');
      assert.ok(tokens.includes('我'));
      assert.ok(tokens.includes('们'));
      assert.ok(tokens.includes('rbac'));
      assert.ok(tokens.includes('权'));
    });

    it('空字符串应返回空数组', () => {
      assert.deepStrictEqual(tokenize(''), []);
      assert.deepStrictEqual(tokenize(null as unknown as string), []);
      assert.deepStrictEqual(tokenize(undefined as unknown as string), []);
    });

    it('应保留英文+数字混合词', () => {
      const tokens = tokenize('OAuth2.0 JWT-token test123abc');
      assert.ok(tokens.includes('oauth2'));
      assert.ok(tokens.includes('jwt'));
      assert.ok(tokens.includes('jwt'));
      assert.ok(tokens.includes('token'));
      assert.ok(tokens.includes('test123abc'));
    });
  });

  // ==================== JSON 文本提取 ====================

  describe('extractTextFromJson', () => {
    it('应从对象中提取所有字符串值', () => {
      const data = { title: '登录设计', description: '支持多因素认证' };
      const text = extractTextFromJson(data);
      assert.ok(text.includes('登录设计'));
      assert.ok(text.includes('支持多因素认证'));
      assert.ok(text.includes('title'));
      assert.ok(text.includes('description'));
    });

    it('应递归处理嵌套对象和数组', () => {
      const data = {
        messages: [
          { role: 'user', content: '你好' },
          { role: 'assistant', content: '你好！有什么可以帮您的？' },
        ],
      };
      const text = extractTextFromJson(data);
      assert.ok(text.includes('你好'));
      assert.ok(text.includes('有什么可以帮您的'));
      assert.ok(text.includes('messages'));
      assert.ok(text.includes('role'));
    });

    it('应处理数字和布尔值', () => {
      const text = extractTextFromJson({ count: 42, active: true });
      assert.ok(text.includes('42'));
      assert.ok(text.includes('true'));
    });

    it('空对象应返回空字符串', () => {
      assert.strictEqual(extractTextFromJson({}), '');
    });
  });

  // ==================== 单例模式 ====================

  describe('单例模式', () => {
    it('getSearchIndex 应返回同一实例', () => {
      const idx1 = getSearchIndex();
      const idx2 = getSearchIndex();
      assert.strictEqual(idx1, idx2);
    });

    it('resetInstance 应重置单例', () => {
      const idx1 = getSearchIndex();
      SearchIndex.resetInstance();
      const idx2 = getSearchIndex();
      assert.notStrictEqual(idx1, idx2);
    });
  });

  // ==================== 全量重建 ====================

  describe('rebuild', () => {
    it('应索引 profile.json', () => {
      storage.write({ identity: { role: '产品经理' } }, 'profile.json');
      const idx = getSearchIndex();
      const count = idx.rebuild(storage);
      assert.strictEqual(count, 1);
      assert.strictEqual(idx.isReady(), true);
    });

    it('应索引项目上下文', () => {
      storage.write({ name: 'TeamFlow', targetUsers: '开发者' }, 'projects', 'teamflow', 'context.json');
      const idx = getSearchIndex();
      const count = idx.rebuild(storage);
      assert.strictEqual(count, 1);

      const results = idx.search('teamflow');
      assert.ok(results.length > 0);
      assert.ok(results.some(r => r.path.includes('context.json')));
    });

    it('应索引对话历史', () => {
      storage.write(
        {
          id: 'c1',
          title: '权限讨论',
          messages: [{ role: 'user', content: 'RBAC 怎么设计', timestamp: '' }],
          keyDecisions: [],
          insights: [],
          tags: [],
        },
        'projects', 'teamflow', 'conversations', '2024-01-01-permissions.json'
      );
      const idx = getSearchIndex();
      const count = idx.rebuild(storage);
      assert.strictEqual(count, 1);

      const results = idx.search('权限');
      assert.strictEqual(results.length, 1);
      assert.ok(results[0].path.includes('conversations'));
    });

    it(' rebuild 前应自动清空旧索引', () => {
      storage.write({ name: 'Old' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);
      assert.ok(idx.search('old').length > 0);

      // 删除旧文件，创建新文件
      fs.unlinkSync(path.join(tempDir, 'profile.json'));
      storage.write({ name: 'New' }, 'profile.json');
      idx.rebuild(storage);
      assert.strictEqual(idx.search('old').length, 0);
      assert.ok(idx.search('new').length > 0);
    });
  });

  // ==================== 增量更新 ====================

  describe('update', () => {
    it('应增量更新单个文件', () => {
      storage.write({ title: '初版' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);
      assert.ok(idx.search('初版').length > 0);

      storage.write({ title: '修订版' }, 'profile.json');
      idx.update(storage, 'profile.json');
      assert.strictEqual(idx.search('初版').length, 0);
      assert.ok(idx.search('修订版').length > 0);
    });

    it('非索引范围路径应忽略', () => {
      storage.write({ note: 'test' }, 'random', 'note.json');
      const idx = getSearchIndex();
      const result = idx.update(storage, 'random/note.json');
      assert.strictEqual(result, false);
    });

    it('不存在的文件应返回 false', () => {
      const idx = getSearchIndex();
      const result = idx.update(storage, 'not-exist.json');
      assert.strictEqual(result, false);
    });
  });

  describe('remove', () => {
    it('应从索引中移除文件', () => {
      storage.write({ name: 'ToRemove' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);
      assert.ok(idx.search('toremove').length > 0);

      idx.remove('profile.json');
      assert.strictEqual(idx.search('toremove').length, 0);
    });
  });

  // ==================== 搜索接口 ====================

  describe('search', () => {
    beforeEach(() => {
      // 准备测试数据
      storage.write(
        {
          id: 'c1',
          title: '权限管理设计',
          messages: [
            { role: 'user', content: '我们需要 RBAC 权限模型', timestamp: '' },
          ],
          keyDecisions: [],
          insights: [],
          tags: [],
        },
        'projects', 'teamflow', 'conversations', 'c1.json'
      );
      storage.write(
        {
          id: 'c2',
          title: 'UI 设计评审',
          messages: [
            { role: 'user', content: '配色方案需要调整', timestamp: '' },
          ],
          keyDecisions: [],
          insights: [],
          tags: [],
        },
        'projects', 'teamflow', 'conversations', 'c2.json'
      );
      storage.write(
        { name: 'TeamFlow', targetUsers: '开发者', coreFeatures: '权限管理' },
        'projects', 'teamflow', 'context.json'
      );
    });

    it('单关键词搜索应返回匹配文件', () => {
      const idx = getSearchIndex();
      idx.rebuild(storage);
      const results = idx.search('权限');
      assert.ok(results.length >= 2); // c1.json 和 context.json
      assert.ok(results.some(r => r.path.includes('c1.json')));
      assert.ok(results.some(r => r.path.includes('context.json')));
    });

    it('多关键词搜索应取交集', () => {
      const idx = getSearchIndex();
      idx.rebuild(storage);
      // "权限" 出现在 c1 和 context 中，"设计" 出现在 c1 和 c2 中
      // 交集应为 c1.json
      const results = idx.search('权限 设计');
      assert.ok(results.length >= 1);
      assert.ok(results.some(r => r.path.includes('c1.json')));
    });

    it('无匹配关键词应返回空数组', () => {
      const idx = getSearchIndex();
      idx.rebuild(storage);
      const results = idx.search('不存在的词 xyzabc');
      assert.deepStrictEqual(results, []);
    });

    it('结果应按匹配度评分降序排列', () => {
      // context.json 包含 "权限管理" 两次（coreFeatures + 项目名称上下文中的字段名也会带来额外匹配）
      // 我们制造一个更明确的场景
      storage.write(
        {
          id: 'c3',
          title: '权限权限权限',
          messages: [],
          keyDecisions: [],
          insights: [],
          tags: [],
        },
        'projects', 'teamflow', 'conversations', 'c3.json'
      );

      const idx = getSearchIndex();
      idx.rebuild(storage);
      const results = idx.search('权限');
      // c3.json 标题中有3个"权限"，应该是最高分
      const c3Result = results.find(r => r.path.includes('c3.json'));
      assert.ok(c3Result);
      assert.ok(c3Result!.score >= 3);
    });

    it('未 rebuild 时应返回空数组', () => {
      const idx = getSearchIndex();
      const results = idx.search('权限');
      assert.deepStrictEqual(results, []);
    });

    it('空关键词应返回空数组', () => {
      const idx = getSearchIndex();
      idx.rebuild(storage);
      assert.deepStrictEqual(idx.search(''), []);
      assert.deepStrictEqual(idx.search('   '), []);
    });
  });

  // ==================== 统计信息 ====================

  describe('getStats', () => {
    it('应返回正确的统计信息', () => {
      storage.write({ role: '产品经理' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);

      const stats = idx.getStats();
      assert.strictEqual(stats.isReady, true);
      assert.strictEqual(stats.totalDocuments, 1);
      assert.ok(stats.totalKeywords > 0);
    });

    it('未 rebuild 时 isReady 应为 false', () => {
      const idx = getSearchIndex();
      const stats = idx.getStats();
      assert.strictEqual(stats.isReady, false);
      assert.strictEqual(stats.totalDocuments, 0);
      assert.strictEqual(stats.totalKeywords, 0);
    });
  });

  // ==================== 事件回调 ====================

  describe('事件回调', () => {
    it('onUpdate 应在 rebuild 时触发', () => {
      storage.write({ name: 'test' }, 'profile.json');
      const idx = getSearchIndex();
      const events: Array<{ type: string; path: string }> = [];

      idx.onUpdate((type, path) => {
        events.push({ type, path });
      });

      idx.rebuild(storage);
      assert.ok(events.some(e => e.type === 'rebuild'));
    });

    it('onUpdate 应在 update 时触发', () => {
      storage.write({ name: 'test' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);

      const events: Array<{ type: string; path: string }> = [];
      idx.onUpdate((type, path) => {
        events.push({ type, path });
      });

      storage.write({ name: 'updated' }, 'profile.json');
      idx.update(storage, 'profile.json');
      assert.ok(events.some(e => e.type === 'update' && e.path === 'profile.json'));
    });

    it('offUpdate 应注销回调', () => {
      storage.write({ name: 'test' }, 'profile.json');
      const idx = getSearchIndex();
      let called = false;

      const handler = (): void => {
        called = true;
      };

      idx.onUpdate(handler);
      idx.offUpdate(handler);
      idx.rebuild(storage);
      assert.strictEqual(called, false);
    });

    it('回调异常不应影响主流程', () => {
      storage.write({ name: 'test' }, 'profile.json');
      const idx = getSearchIndex();
      idx.onUpdate(() => {
        throw new Error('callback error');
      });
      assert.doesNotThrow(() => idx.rebuild(storage));
    });
  });

  // ==================== Storage 写钩子 ====================

  describe('createWriteHook', () => {
    it('writeHook 应触发增量索引更新', () => {
      storage.write({ title: '初版' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);

      const hook = idx.createWriteHook(storage);
      storage.write({ title: '钩子测试' }, 'profile.json');
      hook('profile.json');

      assert.strictEqual(idx.search('初版').length, 0);
      assert.ok(idx.search('钩子测试').length > 0);
    });
  });

  // ==================== clear ====================

  describe('clear', () => {
    it('应清空索引但保留 ready 状态', () => {
      storage.write({ name: 'test' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);
      assert.ok(idx.search('test').length > 0);

      idx.clear();
      assert.strictEqual(idx.search('test').length, 0);
      assert.strictEqual(idx.getStats().totalKeywords, 0);
      assert.strictEqual(idx.getStats().totalDocuments, 0);
    });
  });

  // ==================== 综合场景 ====================

  describe('综合场景', () => {
    it('应正确索引多个项目的混合数据', () => {
      // 项目 A
      storage.write(
        { name: 'TeamFlow', targetUsers: '开发者', coreFeatures: '协作工具' },
        'projects', 'teamflow', 'context.json'
      );
      storage.write(
        {
          id: 'c1',
          title: '权限模型讨论',
          messages: [{ role: 'user', content: 'RBAC 设计方案', timestamp: '' }],
          keyDecisions: [], insights: [], tags: [],
        },
        'projects', 'teamflow', 'conversations', 'c1.json'
      );

      // 项目 B
      storage.write(
        { name: 'ShopMall', targetUsers: '消费者', coreFeatures: '电商购物' },
        'projects', 'shopmall', 'context.json'
      );
      storage.write(
        {
          id: 'c2',
          title: '购物车设计',
          messages: [{ role: 'user', content: '需要支持优惠券', timestamp: '' }],
          keyDecisions: [], insights: [], tags: [],
        },
        'projects', 'shopmall', 'conversations', 'c2.json'
      );

      const idx = getSearchIndex();
      const count = idx.rebuild(storage);
      assert.strictEqual(count, 4);

      // 搜索 "设计" 应命中 teamflow 和 shopmall
      const designResults = idx.search('设计');
      assert.ok(designResults.length >= 2);

      // 搜索 "rbac" 只应命中 teamflow
      const rbacResults = idx.search('rbac');
      assert.strictEqual(rbacResults.length, 1);
      assert.ok(rbacResults[0].path.includes('teamflow'));

      // 搜索 "购物" 只应命中 shopmall
      const shopResults = idx.search('购物');
      assert.ok(shopResults.length >= 1);
      assert.ok(shopResults.every(r => r.path.includes('shopmall')));
    });

    it('删除文件后搜索应不再命中', () => {
      storage.write({ title: '临时数据' }, 'profile.json');
      const idx = getSearchIndex();
      idx.rebuild(storage);
      assert.ok(idx.search('临时').length > 0);

      fs.unlinkSync(path.join(tempDir, 'profile.json'));
      idx.remove('profile.json');
      assert.strictEqual(idx.search('临时').length, 0);
    });
  });
});
