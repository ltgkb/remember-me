{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never"
      },
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode-extension"
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "group": "build",
      "presentation": {
        "reveal": "never"
      },
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode-extension"
      }
    }
  ]
}
